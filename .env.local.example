# Supabase — copy to .env.local (local) and Vercel Environment Variables (production)
# https://supabase.com/dashboard/project/_/settings/api
#
# EXACT names required (watch spelling: SUPABASE not SUBASE):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY   ← never NEXT_PUBLIC_

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: local demo teacher/admin picker (never enable on Vercel production)
# NEXT_PUBLIC_ENABLE_DEMO_LOGIN=true
